<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Pantry scan: in-app camera capture. Declaring CAMERA makes the runtime grant mandatory
         before launching capture — the screen requests it and falls back to the gallery picker
         on denial. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Read suite connection config from the Dragonfly hub (BROKER.md Phase 1). Granted only
         because all suite apps share one signing key; harmless if Dragonfly isn't installed. -->
    <uses-permission android:name="com.dragonfly.permission.READ_SUITE_CONFIG" />

    <!-- API 30+ package visibility: needed to resolve Dragonfly's ContentProvider. -->
    <queries>
        <package android:name="com.dragonfly" />
    </queries>

    <application
        android:name=".CookbookApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cookbook"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Cookbook">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share a recipe page from the browser straight into the URL-import flow. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- AppAuth (BROKER.md Phase 2c) themes its AuthorizationManagementActivity as AppCompat but
             leaves RedirectUriReceiverActivity to inherit the app theme, which isn't AppCompat →
             it can crash on the redirect ("You need to use a Theme.AppCompat theme"). Force an
             AppCompat translucent theme on it (the same one AppAuth uses for its other activity). -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:theme="@style/Theme.AppCompat.Translucent.NoTitleBar"
            tools:node="merge" />

        <!-- Hands the camera a cache-dir target for pantry-scan captures (nothing is kept —
             the photo uploads, gets read, and the file is overwritten by the next scan). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.cookbook.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Home-screen shopping-list widget (v0.3). -->
        <receiver
            android:name=".widget.ShoppingWidgetReceiver"
            android:exported="true"
            android:label="Shopping list">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/shopping_widget_info" />
        </receiver>
    </application>

</manifest>
