# Local dev default matches docker-compose's host-published Postgres (127.0.0.1:5434 -> db:5432).
DATABASE_URL=postgresql+asyncpg://cookbook:cookbook@localhost:5434/cookbook
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- External recipe discovery (Spoonacular) ---
# Powers "Discover recipes": search real recipes and import one as an editable Cookbook recipe.
# Unset ⇒ the discover/import endpoints are disabled (503).
# Option A — direct Spoonacular: free key at https://spoonacular.com/food-api/console#Dashboard
# SPOONACULAR_API_KEY=change-me-to-your-spoonacular-key
# Option B — Spoonacular via RapidAPI: put your RapidAPI key in SPOONACULAR_API_KEY above and set
# the RapidAPI host below (auth then uses X-RapidAPI-Key/Host headers instead of the apiKey param).
# SPOONACULAR_RAPIDAPI_HOST=spoonacular-recipe-food-nutrition-v1.p.rapidapi.com

# --- Plate integration (recipe migration + nutrition breakdown + log-to-diary) ---
# Base URL of Plate's API. Unset ⇒ the integration is disabled.
# PLATE_BASE_URL=https://plate.dragonflymedia.org
# Shared HMAC secret for the cross-app token Cookbook mints (must MATCH Plate's CROSS_APP_SECRET).
# Separate from SECRET_KEY so a normal Cookbook token can't reach the cross-app surface.
# CROSS_APP_SECRET=change-me-to-a-shared-secret-matching-plate

# --- Public deployment hardening (safe to leave unset for local/trusted-network use) ---
# Require this code on /auth/register so the public hostname can't be self-registered against.
# REGISTRATION_INVITE_CODE=change-me-to-a-shared-secret
# Trust forwarded client IPs for per-user rate limiting. Enable ONLY behind a trusted proxy
# (Cloudflare Tunnel / nginx); also run uvicorn with --proxy-headers --forwarded-allow-ips='*'.
# TRUST_PROXY=true
# Send Strict-Transport-Security (enable only when served over HTTPS, e.g. via Cloudflare).
# HSTS_ENABLED=true
# Expose interactive API docs at /docs. Set false to hide them on a public deployment.
# DOCS_ENABLED=true

# --- Password reset email (SMTP) ---
# Without these, reset codes are only printed to the server log (useful for local dev).
# Gmail: create a 16-char App Password at myaccount.google.com/apppasswords (requires 2FA).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=you@gmail.com
# For Outlook / Yahoo (port 465 SSL) set SMTP_USE_SSL=true and SMTP_PORT=465.
# SMTP_USE_SSL=false
